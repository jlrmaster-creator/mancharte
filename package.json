{
  "name": "mancharte",
  "private": true,
  "version": "1.0.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "version": "node scripts/update-version.js",
    "deploy": "npm version patch -m \"chore: bump to v%s\" && git push --follow-tags",
    "release:major": "npm version major -m \"chore: major bump to v%s\" && git push --follow-tags",
    "release:minor": "npm version minor -m \"chore: minor bump to v%s\" && git push --follow-tags",
    "release:patch": "npm version patch -m \"chore: patch bump to v%s\" && git push --follow-tags"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "dexie": "^4.4.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
